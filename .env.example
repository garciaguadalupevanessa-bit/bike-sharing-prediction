# Environment variables required for the bike-sharing prediction project
# Copy this file to .env and replace the placeholder value with your own credentials.

# AEMET OpenData API Key
# Request your own API Key from AEMET OpenData.
AEMET_API_KEY=your_aemet_api_key_here

# Employee key required to create management accounts in the app.
# Demo value used by the app if this variable is not configured in .env.
CLAVE_EMPLEADO_GESTION=1234
